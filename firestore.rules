rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    match /users/{userId} {
      allow read: if isValidId(userId) && (isOwner(userId) || isAdmin());
      allow create: if isValidId(userId) && isOwner(userId) && incoming().keys().hasAll(['name', 'email', 'role']) && incoming().role == 'user';
      allow update: if isValidId(userId) && (
        isAdmin() || 
        (isOwner(userId) && !incoming().diff(existing()).affectedKeys().hasAny(['role', 'walletBalance', 'email', 'createdAt']))
      );
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isValidId(orderId) && (isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid));
      allow create: if isValidId(orderId) && isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isValidId(orderId) && isAdmin();
    }

    match /enrollments/{enrollmentId} {
      allow read: if isValidId(enrollmentId) && (isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid));
      allow create: if isValidId(enrollmentId) && isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isValidId(enrollmentId) && isAdmin();
      allow delete: if isValidId(enrollmentId) && isAdmin();
    }
  }
}
